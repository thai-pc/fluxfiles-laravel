{
    "name": "fluxfiles/laravel",
    "description": "Laravel adapter for FluxFiles file manager",
    "type": "library",
    "license": "MIT",
    "keywords": ["fluxfiles", "laravel", "file-manager", "s3", "r2", "upload"],
    "homepage": "https://github.com/thai-pc/fluxfiles",
    "authors": [
        {
            "name": "thai-pc",
            "homepage": "https://github.com/thai-pc"
        }
    ],
    "support": {
        "issues": "https://github.com/thai-pc/fluxfiles/issues",
        "source": "https://github.com/thai-pc/fluxfiles"
    },
    "require": {
        "php": ">=7.4",
        "fluxfiles/fluxfiles": "^1.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/view": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "FluxFiles\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FluxFiles\\Laravel\\FluxFilesServiceProvider"
            ],
            "aliases": {
                "FluxFiles": "FluxFiles\\Laravel\\FluxFilesFacade"
            }
        }
    },
    "minimum-stability": "stable"
}
